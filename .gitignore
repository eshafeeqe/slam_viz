# Generated by Cargo
# will contain compiled files and executables
/target/

# Cargo files
#
# These files are used to manage the project dependencies and compilation
# process. They should generally be committed to your repository.
# Cargo.toml
# Cargo.lock

# Optional: exclude the vendor directory
#
# If you are using vendored dependencies (e.g., in a corporate environment),
# you might want to uncomment this line.
# /vendor/

# Optional: Exclude editor/IDE-specific files
#
# Depending on your development environment, you might want to add rules for
# files generated by your editor (like VS Code's .vscode folder or JetBrains' .idea folder).
#
# Example for VS Code:
# .vscode/
#
# Example for JetBrains IDEs (RustRover, CLion, etc.):
# .idea/

# Operating System files
# .DS_Store
# Thumbs.db
